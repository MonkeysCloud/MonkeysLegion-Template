{
  "name": "monkeyscloud/monkeyslegion-template",
  "description": "MLView – the MonkeysLegion template engine with components, slots, and caching",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.0",
    "squizlabs/php_codesniffer": "^3.11"
  },
  "autoload": {
    "psr-4": {
      "MonkeysLegion\\Template\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.0.x-dev"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite=Unit",
    "test:integration": "phpunit --testsuite=Integration",
    "test:coverage": "phpunit --coverage-html coverage",
    "phpstan": "phpstan analyse --memory-limit=1G",
    "cs": "phpcs -n",
    "cs-fix": "phpcbf",
    "check": [
      "@cs",
      "@phpstan",
      "@test"
    ]
  }
}