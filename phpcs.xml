<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="MonkeysLegion Coding Standard">
    <description>PSR-12 coding standard for MonkeysLegion-Template</description>

    <!-- Use PSR-12 Standard -->
    <rule ref="PSR12"/>

    <!-- Check src and tests directories -->
    <file>src</file>
    <file>tests</file>

    <!-- Exclude vendor directory -->
    <exclude-pattern>vendor</exclude-pattern>

    <!-- Show progress and colors -->
    <arg value="p"/>
    <arg value="s"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>

    <!-- Ignore warnings on exit -->
    <config name="ignore_warnings_on_exit" value="1"/>
</ruleset>
