#!/usr/bin/env php
<?php

use MonkeysLegion\Cli\CliKernel;
use MonkeysLegion\Template\Console\Commands\LintCommand;

require __DIR__ . '/../vendor/autoload.php';

if (!class_exists(CliKernel::class)) {
    echo "MonkeysLegion CLI not installed.\n";
    exit(1);
}

$kernel = new CliKernel('MLView CLI', '1.0.0');
$kernel->add(new LintCommand());
$kernel->run();
